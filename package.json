    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.1",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.60.0",
